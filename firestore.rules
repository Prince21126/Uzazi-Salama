rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.language in ['fr', 'en', 'sw'];
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'weight', 'lastPeriodDate', 'dueDate', 'weeksPregnant', 'assignedHospitalId', 'language', 'updatedAt']);
      
      match /logs/{logId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.healthScore is number;
      }
    }
  }
}
